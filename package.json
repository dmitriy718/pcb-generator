{
  "name": "pcb-enclosure-generator",
  "version": "0.1.0",
  "description": "Desktop application for generating parametric, 3D-printable PCB enclosures.",
  "license": "MIT",
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "package:linux": "npm run build && electron-builder --linux AppImage",
    "package:win": "npm run build && electron-builder --win nsis",
    "package:mac": "npm run build && electron-builder --mac dmg"
  },
  "dependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "@vitejs/plugin-react": "^5.1.1",
    "electron-log": "^5.4.3",
    "jszip": "^3.10.1",
    "lucide-react": "^0.562.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "three": "^0.185.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.0",
    "electron": "^42.5.0",
    "electron-builder": "^26.1.0",
    "electron-vite": "^4.0.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.1",
    "vitest": "^4.0.16"
  },
  "build": {
    "appId": "com.pcb-enclosure-generator.app",
    "productName": "PCB Enclosure Generator",
    "files": [
      "out/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "resources",
      "output": "release"
    },
    "linux": {
      "target": "AppImage",
      "category": "Graphics"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.graphics-design"
    }
  }
}
